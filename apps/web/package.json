{
  "name": "web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "cf-typegen": "wrangler types",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf node_modules .next .turbo",
    "deploy:staging": "opennextjs-cloudflare build && opennextjs-cloudflare deploy -e=staging",
    "dev": "next dev --turbopack",
    "lint": "eslint --max-warnings 0 --report-unused-disable-directives-severity warn",
    "lint:fix": "eslint --fix",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "start": "next start"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.11.0",
    "@repo/fonts": "workspace:*",
    "next": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@tailwindcss/postcss": "^4",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "eslint": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "wrangler": "catalog:"
  }
}
